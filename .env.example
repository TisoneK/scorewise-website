# ============================================
# ScoreWise Website — Railway Environment Variables
# ============================================
# Copy this to .env for local dev, or set these in Railway dashboard.

# ---- Database (SQLite) ----
# LOCAL DEV:
DATABASE_URL="file:./dev.db"

# RAILWAY (with persistent volume mounted at /data):
# DATABASE_URL="file:/data/scorewise.db"

# ---- NextAuth ----
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-string-in-production"
NEXTAUTH_URL="http://localhost:3000"
# On Railway, set NEXTAUTH_URL to your public URL, e.g.:
# NEXTAUTH_URL="https://scorewise-website.up.railway.app"

# ---- ScoreWise Engine ----
SCOREWISE_API_KEY="your-engine-api-key-here"

# ---- Service URLs (optional — defaults are built in) ----
# SCRAPER_URL="https://flashscore-scraper.up.railway.app"
# ENGINE_URL="https://scorewise-engine.up.railway.app"

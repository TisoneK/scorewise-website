# ============================================
# ScoreWise Website — Environment Variables
# ============================================
# Set these in Vercel dashboard → Settings → Environment Variables
# or copy to .env for local dev

# ---- Turso (Hosted SQLite) ----
# 1. Sign up at https://turso.tech (free)
# 2. Create a database: turso db create scorewise
# 3. Get URL: turso db show scorewise --url
# 4. Get auth token: turso db tokens create scorewise

TURSO_DATABASE_URL="libsql://scorewise-xxxxx.aws-eu-west-1.turso.io"
TURSO_AUTH_TOKEN="eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9..."

# DATABASE_URL is used by Prisma CLI for migrations/push
# For Turso, point it to the same URL
DATABASE_URL="libsql://scorewise-xxxxx.aws-eu-west-1.turso.io"

# ---- NextAuth ----
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-string"

# Vercel auto-sets this, but for local dev:
NEXTAUTH_URL="http://localhost:3000"

# ---- ScoreWise Engine ----
SCOREWISE_API_KEY="your-engine-api-key-here"

# ---- Service URLs (optional — defaults are built in) ----
# SCRAPER_URL="https://flashscore-scraper.up.railway.app"
# ENGINE_URL="https://scorewise-engine.up.railway.app"
